SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: cross-origin browser clients (comma-separated origins). In DEBUG, all origins are allowed if this is empty.
# CORS_ALLOWED_ORIGINS=https://your-frontend.netlify.app,https://your-app.vercel.app

# HTTPS admin/forms behind a reverse proxy (comma-separated origins with scheme).
# CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com

# Set True on Render/Railway/etc. when the app is behind their TLS-terminating proxy.
USE_PROXY_SSL_HEADER=False

# Leave unset for local SQLite. On PaaS, paste the provider Postgres URL.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Some managed Postgres providers require TLS; set True if connections fail without it.
DATABASE_SSL_REQUIRE=False

API_URL=https://translation-api.ghananlp.org/v1/translate
API_SUPPORTED_LANGUAGES_URL=https://translation-api.ghananlp.org/v1/languages
PRIMARY_API_KEY=
SECONDARY_API_KEY=
